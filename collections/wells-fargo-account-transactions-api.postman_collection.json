      "item": [
        {
          "id": "84b6d42d-eb41-4c48-b021-7889e76fd819",
          "name": "List Account Transactions",
          "request": {
            "name": "List Account Transactions",
            "description": {
              "content": "Retrieves a paginated list of transactions for a specified account, supporting ACH, Wire, and RTP/Instant Payment transaction types with intraday and previous-day reporting up to 180 days. Includes unique transaction IDs for deduplication.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v3",
                "accounts",
                ":accountId",
                "transactions"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "startDate",
                  "value": "<date>",
                  "description": "Start date for transaction search (YYYY-MM-DD). Maximum 180 days prior."
                },
                {
                  "disabled": false,
                  "key": "endDate",
                  "value": "<date>",
                  "description": "End date for transaction search (YYYY-MM-DD)."
                },
                {
                  "disabled": false,
                  "key": "transactionType",
                  "value": "<string>",
                  "description": "Filter by transaction type (ACH, WIRE, RTP, CHECK, FED_NOW)."
                },
                {
                  "disabled": false,
                  "key": "debitCreditIndicator",
                  "value": "<string>",
                  "description": "Filter by debit or credit transactions."
                },
                {
                  "disabled": false,
                  "key": "pageSize",
                  "value": "100",
                  "description": "Number of transactions to return per page (default 100, max 500)."
                },
                {
                  "disabled": false,
                  "key": "pageToken",
                  "value": "<string>",
                  "description": "Pagination token from a previous response to fetch next page."
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "accountId",
                  "description": "(Required) The Wells Fargo account identifier."
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": {
              "type": "oauth2",
              "oauth2": [
                {
                  "key": "scope",
                  "value": "accounts:read transactions:read"
                },
                {
                  "key": "accessTokenUrl",
                  "value": "https://api.wellsfargo.com/oauth2/token"
                },
                {
                  "key": "grant_type",
                  "value": "client_credentials"
