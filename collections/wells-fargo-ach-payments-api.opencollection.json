{
  "opencollection": "1.0.0",
  "info": {
    "name": "Wells Fargo ACH Payments API",
    "version": "2.0"
  },
  "items": [
    {
      "info": {
        "name": "ACH Payments",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List ACH Payments",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.wellsfargo.com/v2/ach/payments",
            "params": [
              {
                "name": "startDate",
                "value": "",
                "type": "query",
                "description": "Filter by payment initiation start date (YYYY-MM-DD)."
              },
              {
                "name": "endDate",
                "value": "",
                "type": "query",
                "description": "Filter by payment initiation end date (YYYY-MM-DD)."
              },
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by payment status."
              },
              {
                "name": "pageSize",
                "value": "",
                "type": "query"
              },
              {
                "name": "pageToken",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Retrieves a list of ACH payments initiated by the authenticated customer, with optional filtering by date range, status, and payment type."
        },
        {
          "info": {
            "name": "Initiate ACH Payment",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.wellsfargo.com/v2/ach/payments",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Initiates a single ACH credit or debit transaction. Supports standard ACH and same-day ACH processing. The intelligent routing engine may upgrade eligible transactions to RTP or FedNow for faster settlement."
        },
        {
          "info": {
            "name": "Get ACH Payment",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.wellsfargo.com/v2/ach/payments/:paymentId",
            "params": [
              {
                "name": "paymentId",
                "value": "",
                "type": "path",
                "description": "The ACH payment identifier."
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Retrieves the details and current status of a specific ACH payment by its payment ID, including settlement information and any return codes."
        },
        {
          "info": {
            "name": "Cancel ACH Payment",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.wellsfargo.com/v2/ach/payments/:paymentId",
            "params": [
              {
                "name": "paymentId",
                "value": "",
                "type": "path",
                "description": "The ACH payment identifier."
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Cancels a pending ACH payment that has not yet been submitted to the ACH network. Only payments in PENDING status can be cancelled."
        }
      ]
    },
    {
      "info": {
        "name": "Payment Batches",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Submit ACH Batch",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.wellsfargo.com/v2/ach/batches",
            "body": {
              "type": "json",
              "data": "{}"
            },
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Submits a batch ACH payment file (NACHA-formatted or JSON) containing multiple ACH transactions for processing in a single submission. Supports CTX, CCD, PPD, and WEB ACH transaction codes."
        }
      ]
    },
    {
      "info": {
        "name": "Payment Returns",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List ACH Returns",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.wellsfargo.com/v2/ach/returns",
            "params": [
              {
                "name": "startDate",
                "value": "",
                "type": "query",
                "description": "Filter returns from this date."
              },
              {
                "name": "endDate",
                "value": "",
                "type": "query",
                "description": "Filter returns up to this date."
              },
              {
                "name": "returnType",
                "value": "",
                "type": "query",
                "description": "Filter by return type (RETURN or NOC)."
              }
            ],
            "auth": {
              "type": "oauth2",
              "flow": "client_credentials",
              "accessTokenUrl": "https://api.wellsfargo.com/oauth2/token",
              "credentials": {
                "clientId": "{{clientId}}",
                "clientSecret": "{{clientSecret}}"
              }
            }
          },
          "docs": "Retrieves ACH returns and Notifications of Change (NOC) for the authenticated customer, including return reason codes, original transaction details, and resolution guidance."
        }
      ]
    }
  ],
  "bundled": true
}